PORT=3003
NODE_ENV=development
CLIENT_URL=http://localhost:5173,http://localhost:8088

JWT_SECRET=unused-in-game-service
JWT_REFRESH_SECRET=unused-in-game-service
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_ABSOLUTE_TTL_DAYS=180

GRPC_AUTH_URL=127.0.0.1:50051

REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=2592000000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/
COOKIE_DOMAIN=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=battleship_game
DB_USER=postgres
DB_PASSWORD=postgres
DB_SYNCHRONIZE=false
DB_LOGGING=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=myredispassword
CHAT_HISTORY_LIMIT=80
CHAT_HISTORY_TTL_SECONDS=43200
