PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# Multiple origins are supported with comma-separated values, e.g.
# CLIENT_URL=https://battleship.zuno.works,https://www.battleship.zuno.works

JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-in-production
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_ABSOLUTE_TTL_DAYS=180

REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=2592000000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/
COOKIE_DOMAIN=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=battleship
DB_USER=postgres
DB_PASSWORD=postgres
DB_SYNCHRONIZE=false
DB_LOGGING=false
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/battleship
