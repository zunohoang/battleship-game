PORT=3000
CLIENT_PORT=80
CLIENT_URL=http://YOUR_SERVER_IP

DB_PORT=5432
DB_NAME=battleship
DB_USER=postgres
DB_PASSWORD=change-me

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_ABSOLUTE_TTL_DAYS=180
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=2592000000
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_PATH=/
COOKIE_DOMAIN=
DB_SYNCHRONIZE=false
DB_LOGGING=false

SERVER_IMAGE=ghcr.io/OWNER/p_btship-server:latest
CLIENT_IMAGE=ghcr.io/OWNER/p_btship-client:latest
